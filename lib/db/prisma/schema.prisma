generator kysely {
  provider = "prisma-kysely"
  output   = "../types"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User ↔ Conversation (many-to-many, via ConversationParticipants)

// Conversation ↔ Message (one-to-many)

// User ↔ Message (one-to-many; each message has one sender)

// Message ↔ MessageStatus (one-to-many)

model User {
  id                       String                     @id @default(uuid())
  phoneNumber              String?                    @unique @map("phone_number")
  countryCode              String?                    @map("country_code")
  username                 String
  email                    String?
  emailOtp                 String?                    @map("email_otp")
  OtpExpiry                DateTime?                  @map("otp_expiry")
  profilePicture           String?                    @map("profile_picture")
  about                    String?
  lastSeen                 DateTime?                  @map("last_seen")
  isOnline                 Boolean                    @default(false) @map("is_online")
  isVerified               Boolean                    @default(false) @map("is_verified")
  consent                  Boolean                    @default(false)
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")
  conversation             Conversation[]
  // relations
  conversationParticipants ConversationParticipants[]
  messageSent              Message[]                  @relation("UserMessages")
  messageStatuses          MessageStatus[]
  reactedMessages          Message[]                  @relation("MessageReactions")

  @@map("users")
}

model Conversation {
  id           String                     @id @default(uuid())
  participants ConversationParticipants[]
  type         ConversationType           @default(private)
  name         String?
  createdByRel User                       @relation(fields: [createdBy], references: [id])
  createdBy    String                     @map("created_by")
  messages     Message[]                  @relation("ConversationMessages")
  createdAt    DateTime                   @default(now()) @map("created_at")

  // lastMessage Message? @relation("LastMessage", fields: [lastMessageId], references: [id])
  // lastMessageId String?
  unReadCount Int      @default(0) @map("un_read_count")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("conversations")
}

model ConversationParticipants {
  id             String       @id @default(uuid())
  covnersation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String       @map("conversation_id")
  user           User         @relation(fields: [userId], references: [id])
  userId         String       @map("user_id")
  role           Role         @default(member)
  joinedAt       DateTime     @default(now()) @map("joined_at")
}

model Message {
  id             String       @id @default(uuid())
  conversation   Conversation @relation("ConversationMessages", fields: [conversationId], references: [id])
  conversationId String       @map("conversation_id")
  senderRel      User         @relation("UserMessages", fields: [senderId], references: [id])
  senderId       String       @map("sender_id")
  contentType    Media        @default(text) @map("content_type")
  content        String?
  mediaUrl       String?      @map("media_url")
  reactionUser   User?        @relation("MessageReactions", fields: [reactionUserId], references: [id])
  reactionUserId String?      @map("reaction_user_id")
  reactionEmoji  String?      @map("reaction_emoji")
  replyTo        String?      @map("reply_to")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deleted        Boolean      @default(false)

  messageStatuses MessageStatus[]
  // lastMessageFor Conversation? @relation("LastMessage")
}

model MessageStatus {
  id        String   @id @default(uuid())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId String   @map("message_id")
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @map("user_id")
  status    Status   @default(pending)
  updatedAt DateTime @default(now()) @map("updated_at")
}

// model Status {
//   id String @id @default(uuid())

// }

enum ConversationType {
  private
  group
}

enum Role {
  member
  admin
}

enum Media {
  text
  image
  video
  file
}

enum Status {
  pending
  sent
  delivered
  seen
}

